# ─── Chainflow E2E Test Config ────────────────────────────────────────────────
# Copy this to .env.test and fill in your values.
#
# Run ALL tests (includes real blockchain transactions):
#   node --env-file=.env.test --test "tests/e2e/**/*.test.js"
#
# Run fast validation-only (no blockchain, used by pre-push hook):
#   TEST_SKIP_LIVE=true node --env-file=.env.test --test "tests/e2e/**/*.test.js"
#
# Run a single file:
#   node --env-file=.env.test --test tests/e2e/wallet.test.js

# Server
TEST_BASE_URL=http://localhost:3000

# Basic auth (matches AUTH_USERNAME and AUTH_PASSWORD in your .env)
TEST_AUTH_USERNAME=your_username
TEST_AUTH_PASSWORD=your_password

# ─── Test Wallet ──────────────────────────────────────────────────────────────
# Use a TESTNET-ONLY wallet — never use a wallet that holds real funds.
# Make sure it has testnet ETH/POL/etc. before running lifecycle tests.
TEST_WALLET_NAME=E2E Test Wallet
TEST_PUBLIC_ADDRESS=0xYourPublicAddressHere
TEST_PRIVATE_KEY=0xYourPrivateKeyHere

# ─── Chain Config ─────────────────────────────────────────────────────────────
# Chain IDs must exist in your chains table (seeded via prisma/seed.js)
# 80002 = Polygon Amoy testnet
TEST_CHAIN_IDS=[80002]
TEST_PRIMARY_CHAIN_ID=80002

# ─── Contract Interaction ─────────────────────────────────────────────────────
# A simple contract on the target testnet, e.g. a Storage contract
TEST_CONTRACT_ADDRESS=0xYourContractAddressHere
TEST_FUNCTION_SIGNATURE=function set(uint256 _z)
TEST_FUNCTION_ARGS=[42]

# ─── Native Transfer ──────────────────────────────────────────────────────────
# Any valid address to receive test funds
TEST_TRANSFER_TO=0xRecipientAddressHere
TEST_TRANSFER_VALUE=0.001

# ─── Polling Config ───────────────────────────────────────────────────────────
# How often to poll and how long to wait for a tx to mine
TEST_POLL_INTERVAL_MS=8000
TEST_POLL_TIMEOUT_MS=180000

# ─── Skip live blockchain tests (fast mode) ───────────────────────────────────
# Set to true to skip lifecycle.test.js entirely
# Pre-push hook uses TEST_SKIP_LIVE=true for a quick validation-only run
TEST_SKIP_LIVE=false
