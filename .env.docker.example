PORT=3000

# Database — points to the postgres service name, not localhost
# These are internal Docker credentials — just need to match across all DB_ and POSTGRES_ vars
DB_USER=chainflow
DB_PASS=chainflow
DB_NAME=chainflow
DATABASE_URL=postgresql://chainflow:chainflow@postgres:5432/chainflow

# Postgres container init — read by the postgres Docker image
POSTGRES_USER=chainflow
POSTGRES_PASSWORD=chainflow
POSTGRES_DB=chainflow

# Redis — points to the redis service name, not localhost
REDIS_URL=redis://redis:6379

# Basic Auth — change these
AUTH_USERNAME=your_username
AUTH_PASSWORD=your_password

# Encryption — generate a random 32-byte hex key
ENCRYPTION_KEY=your_32_byte_hex_key