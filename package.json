{
  "name": "taas-transaction-orchestration",
  "version": "1.0.0",
  "type": "module",
  "description": "A Multi-Chain Transaction Orchestrator (TAAS) that manages encrypted wallets, prioritized transaction queues,",
  "main": "src/server.js",
"scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "node --env-file=.env.test --test-concurrency=1 --test tests/e2e/health.test.js tests/e2e/wallet.test.js tests/e2e/transaction.test.js tests/e2e/lifecycle.test.js",
    "test:fast": "TEST_SKIP_LIVE=true node --env-file=.env.test --test-concurrency=1 --test tests/e2e/health.test.js tests/e2e/wallet.test.js tests/e2e/transaction.test.js",
    "test:wallet": "node --env-file=.env.test --test tests/e2e/wallet.test.js",
    "test:transaction": "node --env-file=.env.test --test tests/e2e/transaction.test.js",
    "test:lifecycle": "node --env-file=.env.test --test tests/e2e/lifecycle.test.js",
    "test:health": "node --env-file=.env.test --test tests/e2e/health.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "eslint-plugin-import": "^2.32.0",
    "ethers": "^6.15.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.11",
    "pg": "^8.16.3",
    "prisma": "^6.19.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.7.4"
  }
}
